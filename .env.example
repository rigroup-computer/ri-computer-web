DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Admin — URL rahasia /admin/[SECRET_ADMIN_PATH] — wajib di produksi (lihat lib/admin-guard.ts)
SECRET_ADMIN_PATH="ganti-segment-acak"

# Admin — wajib di produksi
ADMIN_PASSWORD="ganti-password-kuat"
ADMIN_SESSION_SECRET="minimal-16-karakter-acak-disini-long-secret"

SHOP_WHATSAPP_NUMBER="6281234567890"
SHOP_PUBLIC_ADDRESS="Alamat fisik Ri Computer untuk ditampilkan di beranda"
SHOP_PUBLIC_HOURS="Senin–Sabtu · 09:00–15:00"

# Opsional — awalan nomor lacak publik (2–6 huruf), default RC → mis. RC-ABC12XYZ89
TRACKING_PUBLIC_PREFIX="RC"

NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# SEO: `true` hanya di production (domain final). Dev/staging → false atau hapus baris ini.
NEXT_PUBLIC_ALLOW_INDEXING="false"

# Cloudinary — upload lampiran keluhan (wajib untuk unggah foto)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Opsional — folder di Media Library
# CLOUDINARY_BOOKING_FOLDER="booking-issues"
# CLOUDINARY_INVENTORY_FOLDER="inventory-listings"
